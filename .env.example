# GoHome local App API platform model configuration.
# Copy to .env and fill API keys locally. Never commit real keys.

# Optional local server settings
GOHOME_APP_SERVER_PORT=8788
GOHOME_APP_SERVER_HOST=0.0.0.0

# Internal ops page protection. Keep empty for local-only development.
# Set this before cloud deployment, then access ops.html with ?ops_token=...
GOHOME_OPS_TOKEN=

# Multimodal language / vision model: SiliconFlow OpenAI-compatible chat completions endpoint.
GOHOME_MULTIMODAL_BASE_URL=https://api.siliconflow.cn/v1/chat/completions
GOHOME_MULTIMODAL_API_KEY=
GOHOME_MULTIMODAL_MODEL=Qwen/Qwen3.5-27B

# Image generation model: Alibaba Cloud DashScope Wan image generation endpoint.
GOHOME_IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
GOHOME_IMAGE_API_KEY=
GOHOME_IMAGE_MODEL=wan2.7-image

# Optional prompt overrides. Leave empty to use built-in product prompts.
GOHOME_CARE_CARD_PROMPT=
GOHOME_CARE_IMAGE_PROMPT=

# Optional kill switch for external model calls. Defaults to 1 when omitted.
GOHOME_CARE_MODEL_CALLS=1

# Optional image generation kill switch. Defaults to GOHOME_CARE_MODEL_CALLS when omitted.
GOHOME_CARE_IMAGE_CALLS=1
GOHOME_CARE_IMAGE_SIZE=1024*1792
# Optional override: auto detects sync for DashScope multimodal-generation and async for task endpoints.
GOHOME_IMAGE_REQUEST_MODE=

# Optional external model request timeout.
GOHOME_MODEL_REQUEST_TIMEOUT_MS=60000
