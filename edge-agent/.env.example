GOHOME_AGENT_HOST=0.0.0.0
GOHOME_AGENT_PORT=8711
GOHOME_DETECTOR_BACKEND=yolo
GOHOME_YOLO_MODEL=yolo11n.pt
GOHOME_YOLO_IMGSZ=416
GOHOME_YOLO_CONFIDENCE=0.20
GOHOME_POSE_ENABLED=0
GOHOME_POSE_BACKEND=rtmpose
GOHOME_POSE_MODE=lightweight
GOHOME_POSE_RUNTIME_BACKEND=onnxruntime
GOHOME_POSE_DEVICE=cpu
GOHOME_POSE_FALL_THRESHOLD=0.78
GOHOME_POSE_FALL_MIN_CONFIDENCE=0.36
GOHOME_POSE_FALL_MIN_VISIBLE_KEYPOINTS=8
GOHOME_POSE_FALL_MIN_CORE_KEYPOINTS=2
GOHOME_POSE_DET_FREQUENCY=8
GOHOME_POSE_MIN_KEYPOINT_CONFIDENCE=0.30
GOHOME_POSE_MAX_POSES=3
GOHOME_POSE_TRACKING=0
GOHOME_POSE_CACHE_SECONDS=1.8
GOHOME_POSE_CACHE_MAX_MOTION=0.06
GOHOME_ACTIVITY_WINDOW_SECONDS=30
GOHOME_ACTIVITY_MAX_SAMPLES=90
GOHOME_ENABLE_DEMO_CAMERA=0

GOHOME_OBJECT_STORAGE_PROVIDER=signed-localfs
GOHOME_OBJECT_STORAGE_BUCKET=public-media
GOHOME_APP_SERVER_BASE_URL=
GOHOME_DEVICE_API_TOKEN=
GOHOME_UPLOAD_WORKER_ENABLED=1
GOHOME_UPLOAD_WORKER_INTERVAL_SECONDS=5
GOHOME_UPLOAD_WORKER_BATCH_SIZE=4
GOHOME_UPLOAD_REQUEST_TIMEOUT_SECONDS=12
# Real-time preview uses LIVE_RELAY. Keep periodic frame archiving off to avoid
# turning every preview frame into a permanent cloud media asset.
GOHOME_LIVE_FRAME_UPLOAD_ENABLED=0
GOHOME_LIVE_FRAME_UPLOAD_INTERVAL_SECONDS=2
GOHOME_LIVE_RELAY_ENABLED=1
GOHOME_LIVE_RELAY_FPS=8
GOHOME_LIVE_RELAY_WIDTH=640
GOHOME_LIVE_RELAY_HEIGHT=360
GOHOME_LIVE_RELAY_QUALITY=50
GOHOME_LIVE_RELAY_DROP_STALE_FRAMES=4
GOHOME_LIVE_RELAY_REQUEST_TIMEOUT_SECONDS=2
GOHOME_PUBLIC_BASE_URL=
GOHOME_VIDEO_SERVICE_PUBLIC_BASE_URL=
GOHOME_MEDIA_PUBLIC_BASE_URL=
GOHOME_VIDEO_SERVICE_NODE_ID=
GOHOME_VIDEO_SERVICE_REGION=local
GOHOME_VIDEO_SERVICE_ROLE=origin
GOHOME_VIDEO_DISTRIBUTION_NAME=single-origin

GOHOME_NOTIFY_CHANNEL=off
GOHOME_GENERIC_WEBHOOK_URL=
GOHOME_FEISHU_WEBHOOK=
GOHOME_BARK_URL=
GOHOME_TELEGRAM_BOT_TOKEN=
GOHOME_TELEGRAM_CHAT_ID=

GOHOME_APP_PUSH_PROVIDER=off
GOHOME_APP_PUSH_RELAY_URL=
GOHOME_APP_PUSH_RELAY_SECRET=
GOHOME_APP_DEEP_LINK_SCHEME=gohome

GOHOME_APNS_AUTH_KEY_PATH=
GOHOME_APNS_KEY_ID=
GOHOME_APNS_TEAM_ID=
GOHOME_APNS_TOPIC=com.gohome.family
GOHOME_APNS_DEFAULT_ENVIRONMENT=sandbox
GOHOME_APNS_REQUEST_TIMEOUT_SECONDS=8
